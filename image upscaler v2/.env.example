# Copy this file to `.env` and fill in the values

# IP or hostname of the VPS running the upload API. Leave blank to skip uploads.
# Example given by user:
VPS_IP=images.thedailytraveller.online
# Optional: port (443 for HTTPS). The script will omit the port from the URL
# if it matches the default for the scheme.
VPS_PORT=443
# Optional: protocol/scheme to use when contacting the VPS (http or https).
VPS_SCHEME=https
# Enable/disable SSL certificate verification when using https. Set to 0 to
# ignore certificate errors (useful for IP address targets).
VPS_VERIFY_SSL=1
# The API endpoints constructed by the script are:
#   https://images.thedailytraveller.online/create-folder
#   https://images.thedailytraveller.online/upload

# (Optional) Google Sheets configuration. If you want the script to write back URLs,
# set this to the ID of your spreadsheet. Leave blank or unset to disable sheet updates.
GOOGLE_SHEET_ID=1N4AJNhYEhl-vDz1ZbM9JJuZq3hiRm_fu0MhZhwOWILY
WORKSHEET_NAME=Sheet2

# Input filename containing ASINs/URLs (one pipe-separated line per entry).
# Override by setting INPUT_FILE; defaults to "inputimage.txt" in the current folder.
INPUT_FILE=inputimage.txt

# Output directory where processed images are stored. Defaults to "upscalled".
# This can be any relative or absolute path.
OUT_DIR=upscalled

# Maximum dimension (pixels) for the longest side of the upscaled image.
# Defaults to 600; change as needed. Can also be set via TARGET_SIZE env var.
TARGET_SIZE=1500

# (Optional) ScraperAPI key; when provided, lines containing ASINs will use
# the API to fetch product images. If omitted the script will generate a basic
# Amazon image URL (https://.../I/<ASIN>.jpg) which often exists but is not
# guaranteed.
SCRAPER_API_KEY=445d5daaa58906c3aabe6acc559de950
